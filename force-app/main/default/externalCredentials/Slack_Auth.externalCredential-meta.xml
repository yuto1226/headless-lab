<?xml version="1.0" encoding="UTF-8"?>
<ExternalCredential xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Slack Auth</label>
    <authenticationProtocol>Custom</authenticationProtocol>
    <description>External credential used by Apex callouts to authenticate Slack Web API requests.</description>
    <externalCredentialParameters>
        <parameterGroup>Slack_Principal</parameterGroup>
        <parameterName>Slack_Principal</parameterName>
        <parameterType>NamedPrincipal</parameterType>
        <sequenceNumber>1</sequenceNumber>
    </externalCredentialParameters>
    <externalCredentialParameters>
        <parameterName>Authorization</parameterName>
        <parameterType>AuthHeader</parameterType>
        <parameterValue>{!'Bearer ' &amp; $Credential.Slack_Auth.Password}</parameterValue>
        <sequenceNumber>1</sequenceNumber>
    </externalCredentialParameters>
</ExternalCredential>
