                with citationsEnabled = ...
    actions:
        GetOrderByOrderNumber:
            description: "Returns the order information associated with a given contact ID and order number."
            label: "Get Order By Order Number"
            require_user_confirmation: False
            include_in_progress_indicator: True
            source: "SvcCopilotTmpl__GetOrderByOrderNumber"
